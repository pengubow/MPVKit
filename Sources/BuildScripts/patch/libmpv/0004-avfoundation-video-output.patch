+struct avf_render_geometry {
+    int w, h;
+    struct mp_rect src, dst;
+    struct mp_osd_res osd_res;
+};
+
+enum avf_osd_draw_path {
+    AVF_OSD_DRAW_NONE = 0,
+    AVF_OSD_DRAW_DIRECT_LIBASS,
+    AVF_OSD_DRAW_DIRECT_BGRA,
+    AVF_OSD_DRAW_COREGRAPHICS,
+};
+
+struct avf_osd_render_stats {
+    int64_t geometry_ns;
+    int64_t osd_draw_ns;
+    int64_t callback_ns;
+    int64_t buffer_ns;
+    int64_t context_ns;
+    int64_t bitmap_draw_ns;
+    int callbacks;
+    int parts;
+    int format;
+    int draw_path;
+    int64_t src_pixels;
+    int64_t dst_pixels;
+    int bbox_x0, bbox_y0, bbox_x1, bbox_y1;
+    bool has_bbox;
+    bool has_output;
+    bool cache_hit;
+    bool rendered;
+    bool cleared;
+};
+
+struct priv {
+    struct mp_hwdec_ctx hwctx;
+
+    struct mp_image *next_image;
+    double next_pts;
+    CMTimebaseRef timebase;
+    int64_t next_present_host_ns;
+    __strong AVSampleBufferDisplayLayer *displayLayer;
+
+    // OSD/Subtitle support (timed AVSampleBufferDisplayLayer overlay mode)
+    __strong AVSampleBufferDisplayLayer *osdLayer;
+    int64_t osd_change_id;
+    int osd_w, osd_h;
+    struct mp_osd_res osd_res;
+    struct avf_render_geometry render_geometry;
+    struct avf_osd_render_stats osd_stats;
+    bool render_geometry_valid;
+    CVPixelBufferPoolRef osdPool;
+    int osd_pool_w, osd_pool_h;
+    bool osd_needs_enqueue;
+
+    // Compositing mode support
+    bool composite_osd;
+    __strong id<MTLDevice> mtlDevice;
+    __strong CIContext *ciContext;
+    CVPixelBufferPoolRef outputPool;
+    int output_pool_w, output_pool_h;
+    CGImageRef cachedSubtitleImage;
+    CVPixelBufferRef cachedSubtitleBuffer;
+    bool has_subtitle;
+
+    // Software frame upload support
+    CVPixelBufferPoolRef swUploadPool;
+    int sw_pool_w, sw_pool_h;
+    OSType sw_pool_format;
+
+    // Frame counter for periodic maintenance
+    int frame_count;
+
+    // Track if OSD callback was invoked this frame
+    bool osd_callback_invoked;
+
+};
+
+static CGFloat get_screen_scale(void)
+{
+#if TARGET_OS_IPHONE
+    return [UIScreen mainScreen].scale;
+#else
+    NSScreen *screen = [NSScreen mainScreen];
+    return screen ? screen.backingScaleFactor : 1.0;
+#endif
+}
+
+static void reset_osd_render_stats(struct priv *p)
+{
+    p->osd_stats = (struct avf_osd_render_stats){.format = -1};
+}
+
+static const char *sub_bitmap_format_name(int format)
+{
+    switch (format) {
+    case SUBBITMAP_EMPTY: return "empty";
+    case SUBBITMAP_LIBASS: return "libass";
+    case SUBBITMAP_BGRA: return "bgra";
+    case -1: return "none";
+    case -2: return "mixed";
+    default: return "unknown";
+    }
+}
+
+static const char *osd_draw_path_name(int path)
+{
+    switch (path) {
+    case AVF_OSD_DRAW_DIRECT_LIBASS: return "direct-libass";
+    case AVF_OSD_DRAW_DIRECT_BGRA: return "direct-bgra";
+    case AVF_OSD_DRAW_COREGRAPHICS: return "coregraphics";
+    default: return "none";
+    }
+}
+
+static void update_subtitle_bitmap_stats(struct priv *p, struct sub_bitmaps *imgs)
+{
+    if (!imgs)
+        return;
+
+    struct avf_osd_render_stats *s = &p->osd_stats;
+    if (s->format == -1)
+        s->format = imgs->format;
+    else if (s->format != imgs->format)
+        s->format = -2;
+
+    s->parts += imgs->num_parts;
+    s->has_output |= imgs->num_parts > 0;
+
+    for (int i = 0; i < imgs->num_parts; i++) {
+        struct sub_bitmap *sb = &imgs->parts[i];
+        int dw = sb->dw > 0 ? sb->dw : sb->w;
+        int dh = sb->dh > 0 ? sb->dh : sb->h;
+
+        if (sb->w > 0 && sb->h > 0)
+            s->src_pixels += (int64_t)sb->w * sb->h;
+        if (dw > 0 && dh > 0)
+            s->dst_pixels += (int64_t)dw * dh;
+
+        if (dw <= 0 || dh <= 0)
+            continue;
+
+        int x0 = sb->x;
+        int y0 = sb->y;
+        int x1 = sb->x + dw;
+        int y1 = sb->y + dh;
+        if (!s->has_bbox) {
+            s->bbox_x0 = x0;
+            s->bbox_y0 = y0;
+            s->bbox_x1 = x1;
+            s->bbox_y1 = y1;
+            s->has_bbox = true;
+        } else {
+            s->bbox_x0 = MPMIN(s->bbox_x0, x0);
+            s->bbox_y0 = MPMIN(s->bbox_y0, y0);
+            s->bbox_x1 = MPMAX(s->bbox_x1, x1);
+            s->bbox_y1 = MPMAX(s->bbox_y1, y1);
+        }
+    }
+}
+
+static void dispatch_main_sync_safe(dispatch_block_t block);
+
+static void update_avfoundation_geometry(struct vo *vo)
+{
+    struct priv *p = vo->priv;
+
+    if (!p->displayLayer)
+        return;
+
+    __block int width = 0;
+    __block int height = 0;
+    AVSampleBufferDisplayLayer *displayLayer = [p->displayLayer retain];
+    dispatch_main_sync_safe(^{
+        CGFloat scale = displayLayer.contentsScale > 0 ? displayLayer.contentsScale : get_screen_scale();
+        CGSize size = displayLayer.bounds.size;
+        if (size.width <= 0 || size.height <= 0)
+            size = displayLayer.frame.size;
+
+        width = MPMAX(1, (int)(size.width * scale + 0.5));
+        height = MPMAX(1, (int)(size.height * scale + 0.5));
+    });
+    [displayLayer release];
+
+    vo->dwidth = width;
+    vo->dheight = height;
+    vo->monitor_par = 1.0;
+}
+
+static int scale_osd_coord(int value, double scale)
+{
+    return scale > 0 ? MPMAX(0, (int)(value / scale + 0.5)) : value;
+}
+
+static struct avf_render_geometry compute_render_geometry(struct vo *vo,
+                                                          int frame_w,
+                                                          int frame_h)
+{
+    struct priv *p = vo->priv;
+    struct mp_rect src, dst;
+    struct mp_osd_res vo_osd;
+
+    vo_get_src_dst_rects(vo, &src, &dst, &vo_osd);
+
+    if (frame_w <= 0)
+        frame_w = vo->params ? vo->params->w : 0;
+    if (frame_h <= 0)
+        frame_h = vo->params ? vo->params->h : 0;
+
+    if (!p->composite_osd) {
+        int src_w = src.x1 - src.x0;
+        int src_h = src.y1 - src.y0;
+        int dst_w = dst.x1 - dst.x0;
+        int dst_h = dst.y1 - dst.y0;
+        double scale_x = src_w > 0 && dst_w > 0 ? (double)dst_w / src_w : 1.0;
+        double scale_y = src_h > 0 && dst_h > 0 ? (double)dst_h / src_h : 1.0;
+        struct mp_osd_res osd_res = vo_osd;
+
+        osd_res.w = scale_osd_coord(vo_osd.w, scale_x);
+        osd_res.h = scale_osd_coord(vo_osd.h, scale_y);
+        osd_res.ml = scale_osd_coord(vo_osd.ml, scale_x);
+        osd_res.mr = scale_osd_coord(vo_osd.mr, scale_x);
+        osd_res.mt = scale_osd_coord(vo_osd.mt, scale_y);
+        osd_res.mb = scale_osd_coord(vo_osd.mb, scale_y);
+
+        if (osd_res.w <= 0 && frame_w > 0)
+            osd_res.w = frame_w;
+        if (osd_res.h <= 0 && frame_h > 0)
+            osd_res.h = frame_h;
+
+        return (struct avf_render_geometry){
+            .w = osd_res.w,
+            .h = osd_res.h,
+            .src = src,
+            .dst = dst,
+            .osd_res = osd_res,
+        };
+    }
+
+    if (frame_w <= 0 || frame_h <= 0 || vo_osd.w <= 0 || vo_osd.h <= 0) {
+        return (struct avf_render_geometry){0};
+    }
+
+    int params_w = vo->params ? vo->params->w : frame_w;
+    int params_h = vo->params ? vo->params->h : frame_h;
+    if (src.x1 <= src.x0 || src.y1 <= src.y0) {
+        src = (struct mp_rect){0, 0, params_w, params_h};
+    }
+
+    return (struct avf_render_geometry){
+        .w = vo_osd.w,
+        .h = vo_osd.h,
+        .src = src,
+        .dst = dst,
+        .osd_res = vo_osd,
+    };
+}
+
+static void invalidate_render_geometry(struct vo *vo)
+{
+    struct priv *p = vo->priv;
+    p->render_geometry_valid = false;
+}
+
+static void update_render_geometry(struct vo *vo, int frame_w, int frame_h)
+{
+    struct priv *p = vo->priv;
+
+    if (frame_w <= 0)
+        frame_w = vo->params ? vo->params->w : 0;
+    if (frame_h <= 0)
+        frame_h = vo->params ? vo->params->h : 0;
+
+    update_avfoundation_geometry(vo);
+    p->render_geometry = compute_render_geometry(vo, frame_w, frame_h);
+    p->render_geometry_valid = true;
+}
+
+static struct avf_render_geometry get_render_geometry(struct vo *vo,
+                                                      int frame_w,
+                                                      int frame_h)
+{
+    struct priv *p = vo->priv;
+
+    if (!p->render_geometry_valid)
+        update_render_geometry(vo, frame_w, frame_h);
+
+    return p->render_geometry;
+}
+
+// Helper to sync OSD layer frame with display layer frame.
+static void sync_osd_layer_frame(struct vo *vo)
+{
+    struct priv *p = vo->priv;
+
+    update_avfoundation_geometry(vo);
+    invalidate_render_geometry(vo);
+
+    if (p->composite_osd || !p->osdLayer || !p->displayLayer)
+        return;
+    AVSampleBufferDisplayLayer *osdLayer = [p->osdLayer retain];
+    AVSampleBufferDisplayLayer *displayLayer = [p->displayLayer retain];
+    if (!osdLayer || !displayLayer) {
+        [osdLayer release];
+        [displayLayer release];
+        return;
+    }
+    dispatch_async(dispatch_get_main_queue(), ^{
+        [CATransaction begin];
+        [CATransaction setDisableActions:YES];
+        if (osdLayer.superlayer == displayLayer) {
+            osdLayer.frame = displayLayer.bounds;
+        } else {
+            osdLayer.frame = displayLayer.frame;
+            osdLayer.zPosition = displayLayer.zPosition + 1;
+        }
+        osdLayer.contentsScale = displayLayer.contentsScale > 0 ? displayLayer.contentsScale : get_screen_scale();
+        osdLayer.videoGravity = AVLayerVideoGravityResize;
+        [CATransaction commit];
+        [osdLayer release];
+        [displayLayer release];
+    });
+}
+
+static bool wait_until_ready_for_more_media_data(struct vo *vo, int64_t present_host_ns)
+{
+    struct priv *p = vo->priv;
+    if ([p->displayLayer isReadyForMoreMediaData])
+        return true;
+
+    int64_t now = mp_time_ns();
+    int64_t latest = present_host_ns > 0
+        ? present_host_ns - MP_TIME_MS_TO_NS(4)
+        : now + MP_TIME_MS_TO_NS(1);
+    int64_t give_up = MPMIN(now + MP_TIME_MS_TO_NS(2), latest);
+
+    if (give_up <= now) {
+        MP_VERBOSE(vo, "Display layer not ready %.2f ms before PTS; dropping frame\n",
+                   (present_host_ns - now) / 1000000.0);
+        return false;
+    }
+
+    while (![p->displayLayer isReadyForMoreMediaData]) {
+        if (mp_time_ns() >= give_up) {
+            MP_VERBOSE(vo, "Display layer not ready after bounded wait; dropping frame\n");
+            return false;
+        }
+        mp_sleep_ns(MP_TIME_MS_TO_NS(1));
+    }
+
+    return true;
+}
+
+static void dispatch_main_sync_safe(dispatch_block_t block)
+{
+    if ([NSThread isMainThread]) {
+        block();
+    } else {
+        dispatch_sync(dispatch_get_main_queue(), block);
+    }
+}
+
+static AVBufferRef *create_videotoolbox_device_ref(struct vo *vo)
+{
+    AVBufferRef *device_ref = av_hwdevice_ctx_alloc(AV_HWDEVICE_TYPE_VIDEOTOOLBOX);
+    if (!device_ref) {
+        MP_ERR(vo, "Failed to allocate VideoToolbox device\n");
+        return NULL;
+    }
+
+    if (av_hwdevice_ctx_init(device_ref) < 0) {
+        MP_ERR(vo, "Failed to init VideoToolbox device\n");
+        av_buffer_unref(&device_ref);
+        return NULL;
+    }
+
+    return device_ref;
+}
+
+// Generic pixel buffer pool creation helper
+static bool create_pixel_buffer_pool(struct vo *vo, CVPixelBufferPoolRef *poolRef,
+                                     int *cached_w, int *cached_h, OSType *cached_fmt,
+                                     int w, int h, OSType format, const char *name)
+{
+    // Don't recreate if dimensions and format match
+    if (*poolRef && *cached_w == w && *cached_h == h &&
+        (!cached_fmt || *cached_fmt == format))
+        return true;
+
+    // Release old pool
+    if (*poolRef) {
+        CVPixelBufferPoolFlush(*poolRef, kCVPixelBufferPoolFlushExcessBuffers);
+        CVPixelBufferPoolRelease(*poolRef);
+        *poolRef = NULL;
+    }
+
+    NSDictionary *poolAttrs = @{
+        (id)kCVPixelBufferPoolMinimumBufferCountKey: @3,
+        (id)kCVPixelBufferPoolMaximumBufferAgeKey: @1.0
+    };
+
+    NSDictionary *bufferAttrs = @{
+        (id)kCVPixelBufferPixelFormatTypeKey: @(format),
+        (id)kCVPixelBufferWidthKey: @(w),
+        (id)kCVPixelBufferHeightKey: @(h),
+        (id)kCVPixelBufferMetalCompatibilityKey: @YES,
+        (id)kCVPixelBufferIOSurfacePropertiesKey: @{}
+    };
+
+    CVReturn status = CVPixelBufferPoolCreate(kCFAllocatorDefault,
+        (__bridge CFDictionaryRef)poolAttrs,
+        (__bridge CFDictionaryRef)bufferAttrs, poolRef);
+
+    if (status != kCVReturnSuccess) {
+        MP_ERR(vo, "Failed to create %s pool: %d\n", name, status);
+        return false;
+    }
+
+    *cached_w = w;
+    *cached_h = h;
+    if (cached_fmt)
+        *cached_fmt = format;
+
+    MP_VERBOSE(vo, "Created %s pool: %dx%d format=%d\n", name, w, h, (int)format);
+    return true;
+}
+
+
+// Create output pool matching the source format to preserve quality
+// Strategy: Use BGRA for 8-bit SDR (matches subtitle format, avoids half-float precision loss)
+//           Use RGBA half-float for 10-bit HDR (necessary for HDR precision)
+static bool create_output_pool(struct vo *vo, int w, int h, OSType format)
+{
+    struct priv *p = vo->priv;
+
+    OSType outputFormat;
+
+    // For 10-bit HDR content (P010), use RGBA half-float to preserve HDR precision
+    if (format == kCVPixelFormatType_420YpCbCr10BiPlanarVideoRange ||
+        format == kCVPixelFormatType_420YpCbCr10BiPlanarFullRange) {
+        outputFormat = kCVPixelFormatType_64RGBAHalf;
+    }
+    // For 8-bit SDR content, use BGRA (matches subtitle format, avoids half-float precision issues)
+    // This minimizes format conversions and preserves quality better than RGBA half-float
+    else if (format == kCVPixelFormatType_420YpCbCr8BiPlanarVideoRange ||
+             format == kCVPixelFormatType_420YpCbCr8BiPlanarFullRange ||
+             format == kCVPixelFormatType_420YpCbCr8Planar) {
+        outputFormat = kCVPixelFormatType_32BGRA;
+    }
+    // Default to RGBA half-float for unknown formats (HDR-safe fallback)
+    else {
+        outputFormat = kCVPixelFormatType_64RGBAHalf;
+    }
+
+    return create_pixel_buffer_pool(vo, &p->outputPool, &p->output_pool_w,
+        &p->output_pool_h, NULL, w, h, outputFormat, "composite output");
+}
