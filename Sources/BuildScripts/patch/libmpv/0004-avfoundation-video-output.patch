+static void set_colorspace_from_attachments(CVPixelBufferRef pixbuf)
+{
+    CFDictionaryRef attachments = CVBufferGetAttachments(
+        pixbuf, kCVAttachmentMode_ShouldPropagate);
+    if (!attachments)
+        return;
+
+    CGColorSpaceRef colorspace = CVImageBufferCreateColorSpaceFromAttachments(attachments);
+    if (!colorspace)
+        return;
+
+    CVBufferSetAttachment(pixbuf, kCVImageBufferCGColorSpaceKey, colorspace,
+                          kCVAttachmentMode_ShouldPropagate);
+    CGColorSpaceRelease(colorspace);
+}
+
+static void tag_pixel_buffer_color_metadata(CVPixelBufferRef pixbuf,
+                                            const struct mp_image_params *params)
+{
+    CFStringRef primaries = get_cv_color_primaries(params->color.primaries);
+    CFStringRef transfer = get_cv_transfer_function(params->color.transfer);
+    CFStringRef matrix = get_cv_ycbcr_matrix(params->repr.sys);
+
+    if (primaries) {
+        CVBufferSetAttachment(pixbuf, kCVImageBufferColorPrimariesKey,
+                              primaries, kCVAttachmentMode_ShouldPropagate);
+    }
+    if (transfer) {
+        CVBufferSetAttachment(pixbuf, kCVImageBufferTransferFunctionKey,
+                              transfer, kCVAttachmentMode_ShouldPropagate);
+    }
+    if (matrix) {
+        CVBufferSetAttachment(pixbuf, kCVImageBufferYCbCrMatrixKey,
+                              matrix, kCVAttachmentMode_ShouldPropagate);
+    }
+    if (primaries || transfer || matrix)
+        set_colorspace_from_attachments(pixbuf);
+}
+
+// Copy HDR metadata from source to destination pixel buffer
+static void copy_hdr_metadata(CVPixelBufferRef src, CVPixelBufferRef dst)
+{
+    const CFStringRef keys[] = {
+        kCVImageBufferTransferFunctionKey,      // PQ for HDR10/DolbyVision, HLG for HLG
+        kCVImageBufferColorPrimariesKey,        // BT.2020 for HDR
+        kCVImageBufferYCbCrMatrixKey,
+        kCVImageBufferMasteringDisplayColorVolumeKey,  // HDR10 static metadata
+        kCVImageBufferContentLightLevelInfoKey,        // MaxCLL, MaxFALL
+    };
+
+    for (size_t i = 0; i < MP_ARRAY_SIZE(keys); i++) {
+        CFTypeRef value = CVBufferGetAttachment(src, keys[i], NULL);
+        if (value) {
+            CVBufferSetAttachment(dst, keys[i], value, kCVAttachmentMode_ShouldPropagate);
+        }
+    }
+
+    set_colorspace_from_attachments(dst);
+}
+
+// Map mpv image format to CVPixelBuffer format
+static OSType get_cv_pixel_format(int imgfmt)
+{
+    switch (imgfmt) {
+        case IMGFMT_NV12:
+            return kCVPixelFormatType_420YpCbCr8BiPlanarVideoRange;
+        case IMGFMT_420P:
+            return kCVPixelFormatType_420YpCbCr8Planar;
+        case IMGFMT_P010:
+            return kCVPixelFormatType_420YpCbCr10BiPlanarVideoRange;
+        default:
+            return 0;
+    }
+}
+
+// Create software upload pool
+static bool create_sw_upload_pool(struct vo *vo, int w, int h, OSType format)
+{
+    struct priv *p = vo->priv;
+    return create_pixel_buffer_pool(vo, &p->swUploadPool, &p->sw_pool_w,
+        &p->sw_pool_h, &p->sw_pool_format, w, h, format, "software upload");
+}
+
+static bool create_osd_pool(struct vo *vo, int w, int h)
+{
+    struct priv *p = vo->priv;
+    return create_pixel_buffer_pool(vo, &p->osdPool, &p->osd_pool_w,
+        &p->osd_pool_h, NULL, w, h, kCVPixelFormatType_32BGRA, "OSD overlay");
+}
+
+// Upload a software-decoded frame to CVPixelBuffer
+static CVPixelBufferRef upload_software_frame(struct vo *vo, struct mp_image *mpi)
+{
+    struct priv *p = vo->priv;
+
+    OSType cvFormat = get_cv_pixel_format(mpi->imgfmt);
+    if (!cvFormat) {
+        MP_ERR(vo, "Unsupported software format: %d\n", mpi->imgfmt);
+        return NULL;
+    }
+
+    int w = mpi->w;
+    int h = mpi->h;
+
+    if (!create_sw_upload_pool(vo, w, h, cvFormat))
+        return NULL;
+
+    CVPixelBufferRef pixbuf = NULL;
+    CVReturn status = CVPixelBufferPoolCreatePixelBuffer(
+        kCFAllocatorDefault, p->swUploadPool, &pixbuf);
+
+    if (status != kCVReturnSuccess || !pixbuf) {
+        MP_ERR(vo, "Failed to get upload buffer: %d\n", status);
+        return NULL;
+    }
+
+    CVPixelBufferLockBaseAddress(pixbuf, 0);
+
+    size_t planeCount = CVPixelBufferGetPlaneCount(pixbuf);
+
+    if (planeCount == 0) {
+        // Non-planar format
+        void *dst = CVPixelBufferGetBaseAddress(pixbuf);
+        size_t dstStride = CVPixelBufferGetBytesPerRow(pixbuf);
+        size_t srcStride = mpi->stride[0];
+
+        // Fast path: single memcpy if strides match
+        if (dstStride == srcStride) {
+            memcpy(dst, mpi->planes[0], dstStride * h);
+        } else {
+            size_t copyBytes = MPMIN(dstStride, srcStride);
+            for (int y = 0; y < h; y++) {
+                memcpy((uint8_t *)dst + y * dstStride,
+                       mpi->planes[0] + y * srcStride,
+                       copyBytes);
+            }
+        }
+    } else {
+        // Planar format (NV12, YUV420P, P010)
+        for (size_t plane = 0; plane < planeCount && plane < MP_MAX_PLANES; plane++) {
+            void *dst = CVPixelBufferGetBaseAddressOfPlane(pixbuf, plane);
+            size_t dstStride = CVPixelBufferGetBytesPerRowOfPlane(pixbuf, plane);
+            size_t dstHeight = CVPixelBufferGetHeightOfPlane(pixbuf, plane);
+
+            uint8_t *src = mpi->planes[plane];
+            size_t srcStride = mpi->stride[plane];
+
+            if (!src)
+                continue;
+
+            // Fast path: single memcpy if strides match
+            if (dstStride == srcStride) {
+                memcpy(dst, src, dstStride * dstHeight);
+            } else {
+                size_t copyBytes = MPMIN(dstStride, srcStride);
+                for (size_t y = 0; y < dstHeight; y++) {
+                    memcpy((uint8_t *)dst + y * dstStride,
+                           src + y * srcStride,
+                           copyBytes);
+                }
+            }
+        }
+    }
+
+    CVPixelBufferUnlockBaseAddress(pixbuf, 0);
+    tag_pixel_buffer_color_metadata(pixbuf, &mpi->params);
+
+    return pixbuf;
+}
+
+static void draw_subtitle_bitmaps(CGContextRef context, struct sub_bitmaps *imgs,
+                                  int h)
+{
+    CGColorSpaceRef partColorSpace = (imgs->format == SUBBITMAP_BGRA)
+        ? CGColorSpaceCreateDeviceRGB() : NULL;
+
+    for (int i = 0; i < imgs->num_parts; i++) {
+        struct sub_bitmap *sb = &imgs->parts[i];
+
+        if (!sb->bitmap || sb->w <= 0 || sb->h <= 0)
+            continue;
+
+        CGDataProviderRef provider = CGDataProviderCreateWithData(
+            NULL, sb->bitmap, sb->stride * sb->h, NULL);
+
+        if (!provider)
+            continue;
+
+        if (imgs->format == SUBBITMAP_BGRA) {
+            CGImageRef partImage = CGImageCreate(
+                sb->w, sb->h, 8, 32, sb->stride, partColorSpace,
+                kCGImageAlphaPremultipliedFirst | kCGBitmapByteOrder32Little,
+                provider, NULL, false, kCGRenderingIntentDefault);
+
+            if (partImage) {
+                CGRect destRect = CGRectMake(sb->x, h - sb->y - sb->dh, sb->dw, sb->dh);
+                CGContextDrawImage(context, destRect, partImage);
+                CGImageRelease(partImage);
+            }
+        } else if (imgs->format == SUBBITMAP_LIBASS) {
+            // Invert decode array: libass uses 255=opaque, but CGImageMask uses 0=paint
+            CGFloat decode[] = {1, 0};
+            CGImageRef mask = CGImageMaskCreate(
+                sb->w, sb->h, 8, 8, sb->stride, provider, decode, false);
+
+            if (mask) {
+                CGContextSaveGState(context);
+                CGRect destRect = CGRectMake(sb->x, h - sb->y - sb->dh, sb->dw, sb->dh);
+                CGContextClipToMask(context, destRect, mask);
+
+                uint32_t c = sb->libass.color;
+                float r = ((c >> 24) & 0xFF) / 255.0f;
+                float g = ((c >> 16) & 0xFF) / 255.0f;
+                float b = ((c >> 8) & 0xFF) / 255.0f;
+                float a = 1.0f - ((c >> 0) & 0xFF) / 255.0f;
+
+                CGContextSetRGBFillColor(context, r, g, b, a);
+                CGContextFillRect(context, destRect);
+                CGContextRestoreGState(context);
+                CGImageRelease(mask);
+            }
+        }
+
+        CGDataProviderRelease(provider);
+    }
+
+    if (partColorSpace)
+        CGColorSpaceRelease(partColorSpace);
+}
+
+static int get_direct_osd_draw_path(struct sub_bitmaps *imgs)
+{
+    if (!imgs || imgs->num_parts <= 0)
+        return AVF_OSD_DRAW_NONE;
+
+    int path = AVF_OSD_DRAW_NONE;
+    if (imgs->format == SUBBITMAP_LIBASS) {
+        path = AVF_OSD_DRAW_DIRECT_LIBASS;
+    } else if (imgs->format == SUBBITMAP_BGRA) {
+        path = AVF_OSD_DRAW_DIRECT_BGRA;
+    } else {
+        return AVF_OSD_DRAW_NONE;
+    }
+
+    for (int i = 0; i < imgs->num_parts; i++) {
+        struct sub_bitmap *sb = &imgs->parts[i];
+        if (!sb->bitmap || sb->w <= 0 || sb->h <= 0)
+            continue;
+
+        int dw = sb->dw > 0 ? sb->dw : sb->w;
+        int dh = sb->dh > 0 ? sb->dh : sb->h;
+        if (dw != sb->w || dh != sb->h)
+            return AVF_OSD_DRAW_COREGRAPHICS;
+    }
+
+    return path;
+}
+
+static void blend_libass_bgra(uint8_t *dst, size_t dst_stride,
+                              uint8_t *src, int src_stride,
+                              int w, int h, uint32_t color)
+{
+    const unsigned int r = (color >> 24) & 0xff;
+    const unsigned int g = (color >> 16) & 0xff;
+    const unsigned int b = (color >>  8) & 0xff;
+    const unsigned int a = 0xff - (color & 0xff);
+
+    if (!a)
+        return;
+
+    for (int y = 0; y < h; y++) {
+        uint32_t *dstrow = (uint32_t *)dst;
+        for (int x = 0; x < w; x++) {
+            const unsigned int v = src[x];
+            if (!v)
+                continue;
+
+            unsigned int aa = a * v;
+            unsigned int inv = 255 * 255 - aa;
+            uint32_t dstpix = dstrow[x];
+            unsigned int dstb =  dstpix        & 0xff;
+            unsigned int dstg = (dstpix >>  8) & 0xff;
+            unsigned int dstr = (dstpix >> 16) & 0xff;
+            unsigned int dsta = (dstpix >> 24) & 0xff;
+
+            dstb = (v * b * a + dstb * inv + 32512) / (255 * 255);
+            dstg = (v * g * a + dstg * inv + 32512) / (255 * 255);
+            dstr = (v * r * a + dstr * inv + 32512) / (255 * 255);
+            dsta = (aa * 255 + dsta * inv + 32512) / (255 * 255);
+            dstrow[x] = dstb | (dstg << 8) | (dstr << 16) | (dsta << 24);
+        }
+        dst += dst_stride;
+        src += src_stride;
+    }
+}
+
+static void blend_bgra_over_bgra(uint8_t *dst, size_t dst_stride,
+                                 uint8_t *src, int src_stride,
+                                 int w, int h)
+{
+    for (int y = 0; y < h; y++) {
+        uint32_t *srcrow = (uint32_t *)src;
+        uint32_t *dstrow = (uint32_t *)dst;
+        for (int x = 0; x < w; x++) {
+            uint32_t srcpix = srcrow[x];
+            unsigned int srca = (srcpix >> 24) & 0xff;
+            if (!srca)
+                continue;
+            if (srca == 0xff || !dstrow[x]) {
+                dstrow[x] = srcpix;
+                continue;
+            }
+
+            uint32_t dstpix = dstrow[x];
+            unsigned int inv = 0xff - srca;
+            unsigned int srcb =  srcpix        & 0xff;
+            unsigned int srcg = (srcpix >>  8) & 0xff;
+            unsigned int srcr = (srcpix >> 16) & 0xff;
+            unsigned int dstb =  dstpix        & 0xff;
+            unsigned int dstg = (dstpix >>  8) & 0xff;
+            unsigned int dstr = (dstpix >> 16) & 0xff;
+            unsigned int dsta = (dstpix >> 24) & 0xff;
+
+            dstb = MPMIN(0xff, srcb + (dstb * inv + 127) / 255);
+            dstg = MPMIN(0xff, srcg + (dstg * inv + 127) / 255);
+            dstr = MPMIN(0xff, srcr + (dstr * inv + 127) / 255);
+            dsta = MPMIN(0xff, srca + (dsta * inv + 127) / 255);
+            dstrow[x] = dstb | (dstg << 8) | (dstr << 16) | (dsta << 24);
+        }
+        dst += dst_stride;
+        src += src_stride;
+    }
+}
+
+static void draw_direct_libass_bitmap(uint8_t *base, size_t stride,
+                                      int w, int h, struct sub_bitmap *sb)
+{
+    int x0 = MPCLAMP(sb->x, 0, w);
+    int y0 = MPCLAMP(sb->y, 0, h);
+    int x1 = MPCLAMP(sb->x + sb->w, 0, w);
+    int y1 = MPCLAMP(sb->y + sb->h, 0, h);
+    int draw_w = x1 - x0;
+    int draw_h = y1 - y0;
+    if (draw_w <= 0 || draw_h <= 0)
+        return;
+
+    uint8_t *dst = base + (size_t)y0 * stride + (size_t)x0 * 4;
+    uint8_t *src = (uint8_t *)sb->bitmap + (y0 - sb->y) * sb->stride + (x0 - sb->x);
+    blend_libass_bgra(dst, stride, src, sb->stride, draw_w, draw_h, sb->libass.color);
+}
+
+static void draw_direct_bgra_bitmap(uint8_t *base, size_t stride,
+                                    int w, int h, struct sub_bitmap *sb)
+{
+    int dw = sb->dw > 0 ? sb->dw : sb->w;
+    int dh = sb->dh > 0 ? sb->dh : sb->h;
+    int x0 = MPCLAMP(sb->x, 0, w);
+    int y0 = MPCLAMP(sb->y, 0, h);
+    int x1 = MPCLAMP(sb->x + dw, 0, w);
+    int y1 = MPCLAMP(sb->y + dh, 0, h);
+    int draw_w = x1 - x0;
+    int draw_h = y1 - y0;
+    if (draw_w <= 0 || draw_h <= 0)
+        return;
+
+    uint8_t *dst = base + (size_t)y0 * stride + (size_t)x0 * 4;
+    uint8_t *src = (uint8_t *)sb->bitmap + (y0 - sb->y) * sb->stride + (size_t)(x0 - sb->x) * 4;
+    blend_bgra_over_bgra(dst, stride, src, sb->stride, draw_w, draw_h);
+}
+
+static bool draw_subtitle_bitmaps_direct(struct priv *p, uint8_t *base,
+                                         size_t stride, int w, int h,
+                                         struct sub_bitmaps *imgs)
+{
+    int path = get_direct_osd_draw_path(imgs);
+    if (path != AVF_OSD_DRAW_DIRECT_LIBASS && path != AVF_OSD_DRAW_DIRECT_BGRA)
+        return false;
+
+    p->osd_stats.draw_path = path;
+
+    for (int i = 0; i < imgs->num_parts; i++) {
+        struct sub_bitmap *sb = &imgs->parts[i];
+        if (!sb->bitmap || sb->w <= 0 || sb->h <= 0)
+            continue;
+        if (path == AVF_OSD_DRAW_DIRECT_LIBASS)
+            draw_direct_libass_bitmap(base, stride, w, h, sb);
+        else
+            draw_direct_bgra_bitmap(base, stride, w, h, sb);
+    }
+
+    return true;
+}
+
+// Render subtitle bitmap to CGImage (used by compositing mode)
+static CGImageRef render_subtitle_image(struct vo *vo, struct sub_bitmaps *imgs)
+{
+    struct priv *p = vo->priv;
+
+    if (!imgs || imgs->num_parts == 0)
+        return NULL;
+
+    int w = p->osd_w;
+    int h = p->osd_h;
+
+    if (w <= 0 || h <= 0)
+        return NULL;
+
+    int64_t context_start = mp_time_ns();
+    CGColorSpaceRef colorSpace = CGColorSpaceCreateDeviceRGB();
+    if (!colorSpace) {
+        p->osd_stats.context_ns += mp_time_ns() - context_start;
+        return NULL;
+    }
+
+    CGContextRef context = CGBitmapContextCreate(
+        NULL, w, h, 8, w * 4, colorSpace,
+        kCGImageAlphaPremultipliedLast | kCGBitmapByteOrder32Big
+    );
+    CGColorSpaceRelease(colorSpace);
+    p->osd_stats.context_ns += mp_time_ns() - context_start;
+
+    if (!context)
+        return NULL;
+
+    CGContextClearRect(context, CGRectMake(0, 0, w, h));
+    int64_t draw_start = mp_time_ns();
+    p->osd_stats.draw_path = AVF_OSD_DRAW_COREGRAPHICS;
+    draw_subtitle_bitmaps(context, imgs, h);
+    p->osd_stats.bitmap_draw_ns += mp_time_ns() - draw_start;
+
+    CGImageRef result = CGBitmapContextCreateImage(context);
+    CGContextRelease(context);
+
+    return result;
+}
+
+static CVPixelBufferRef create_empty_osd_pixel_buffer(struct vo *vo)
+{
+    struct priv *p = vo->priv;
+    int w = p->osd_w;
+    int h = p->osd_h;
+
+    if (w <= 0 || h <= 0)
+        return NULL;
+
+    if (!create_osd_pool(vo, w, h))
+        return NULL;
+
+    CVPixelBufferRef pixbuf = NULL;
+    CVReturn status = CVPixelBufferPoolCreatePixelBuffer(
+        kCFAllocatorDefault, p->osdPool, &pixbuf);
+
+    if (status != kCVReturnSuccess || !pixbuf) {
+        MP_ERR(vo, "Failed to get OSD overlay buffer: %d\n", status);
+        return NULL;
+    }
+
+    CVPixelBufferLockBaseAddress(pixbuf, 0);
+    void *base = CVPixelBufferGetBaseAddress(pixbuf);
+    size_t stride = CVPixelBufferGetBytesPerRow(pixbuf);
+    if (!base || !stride) {
+        CVPixelBufferUnlockBaseAddress(pixbuf, 0);
+        CVPixelBufferRelease(pixbuf);
+        return NULL;
+    }
+    memset(base, 0, stride * h);
+
+    CVPixelBufferUnlockBaseAddress(pixbuf, 0);
+    return pixbuf;
+}
+
+static CVPixelBufferRef render_subtitle_pixel_buffer(struct vo *vo,
+                                                     struct sub_bitmaps *imgs)
+{
+    struct priv *p = vo->priv;
+    int w = p->osd_w;
+    int h = p->osd_h;
+
+    if (!imgs || imgs->num_parts == 0)
+        return NULL;
+
+    int64_t buffer_start = mp_time_ns();
+    CVPixelBufferRef pixbuf = create_empty_osd_pixel_buffer(vo);
+    p->osd_stats.buffer_ns += mp_time_ns() - buffer_start;
+    if (!pixbuf)
+        return NULL;
+
+    CVPixelBufferLockBaseAddress(pixbuf, 0);
+    void *base = CVPixelBufferGetBaseAddress(pixbuf);
+    size_t stride = CVPixelBufferGetBytesPerRow(pixbuf);
+    if (!base || !stride) {
+        CVPixelBufferUnlockBaseAddress(pixbuf, 0);
+        CVPixelBufferRelease(pixbuf);
+        return NULL;
+    }
+
+    int64_t direct_draw_start = mp_time_ns();
+    if (draw_subtitle_bitmaps_direct(p, base, stride, w, h, imgs)) {
+        p->osd_stats.bitmap_draw_ns += mp_time_ns() - direct_draw_start;
+        CVPixelBufferUnlockBaseAddress(pixbuf, 0);
+        return pixbuf;
+    }
+
+    int64_t context_start = mp_time_ns();
+    CGColorSpaceRef colorSpace = CGColorSpaceCreateDeviceRGB();
+    CGContextRef context = colorSpace ? CGBitmapContextCreate(
+        base, w, h, 8, stride, colorSpace,
+        kCGImageAlphaPremultipliedFirst | kCGBitmapByteOrder32Little
+    ) : NULL;
+
+    if (colorSpace)
+        CGColorSpaceRelease(colorSpace);
+    p->osd_stats.context_ns += mp_time_ns() - context_start;
+
+    if (!context) {
+        CVPixelBufferUnlockBaseAddress(pixbuf, 0);
+        CVPixelBufferRelease(pixbuf);
+        return NULL;
+    }
+
+    int64_t draw_start = mp_time_ns();
+    p->osd_stats.draw_path = AVF_OSD_DRAW_COREGRAPHICS;
+    draw_subtitle_bitmaps(context, imgs, h);
+    p->osd_stats.bitmap_draw_ns += mp_time_ns() - draw_start;
+    CGContextRelease(context);
+
+    CVPixelBufferUnlockBaseAddress(pixbuf, 0);
+    return pixbuf;
+}
+
+static CMSampleBufferRef create_osd_sample_buffer(struct vo *vo,
+                                                  int64_t present_host_ns,
+                                                  bool *needed)
+{
+    struct priv *p = vo->priv;
+
+    if (needed)
+        *needed = false;
+
+    if (p->composite_osd || !p->osd_needs_enqueue)
+        return NULL;
+
+    if (needed)
+        *needed = true;
+
+    CVPixelBufferRef pixbuf = NULL;
+    if (p->has_subtitle && p->cachedSubtitleBuffer) {
+        pixbuf = CVPixelBufferRetain(p->cachedSubtitleBuffer);
+    } else {
+        pixbuf = create_empty_osd_pixel_buffer(vo);
+    }
+    if (!pixbuf)
+        return NULL;
+
+    int64_t pts_ns = present_host_ns > 0 ? present_host_ns : mp_time_ns();
+    CMSampleTimingInfo info = {
+        .presentationTimeStamp = CMTimeMake(pts_ns, NSEC_PER_SEC),
+        .duration = kCMTimeInvalid,
+        .decodeTimeStamp = kCMTimeInvalid
+    };
+
+    CMFormatDescriptionRef format = NULL;
+    CMSampleBufferRef buf = NULL;
+    OSStatus err = CMVideoFormatDescriptionCreateForImageBuffer(NULL, pixbuf, &format);
+    if (err == noErr && format)
+        err = CMSampleBufferCreateReadyWithImageBuffer(NULL, pixbuf, format, &info, &buf);
+
+    if (format)
+        CFRelease(format);
+    CVPixelBufferRelease(pixbuf);
+
+    if (err != noErr || !buf) {
+        MP_ERR(vo, "Failed to create OSD sample buffer: %d\n", (int)err);
+        return NULL;
+    }
+
+    return buf;
+}
+
+static bool enqueue_osd_sample(struct vo *vo, CMSampleBufferRef buf)
+{
+    struct priv *p = vo->priv;
+
+    if (!buf)
+        return true;
+
+    AVSampleBufferDisplayLayer *osdLayer = [p->osdLayer retain];
+    if (!osdLayer)
+        return false;
+
+    if (![osdLayer isReadyForMoreMediaData]) {
+        MP_VERBOSE(vo, "OSD layer not ready; dropping subtitle sample for this frame\n");
+        [osdLayer release];
+        return false;
+    }
+
+    [osdLayer enqueueSampleBuffer:buf];
+    [osdLayer release];
+
+    return true;
+}
+
+// Callback for osd_draw - renders subtitle bitmaps
+static void draw_osd_cb(void *ctx, struct sub_bitmaps *imgs)
+{
+    struct vo *vo = ctx;
+    struct priv *p = vo->priv;
+    int64_t callback_start = mp_time_ns();
+
+    p->osd_stats.callbacks += 1;
+
+    // Mark that callback was invoked this frame
+    p->osd_callback_invoked = true;
+    update_subtitle_bitmap_stats(p, imgs);
+
+    // Clear subtitles when there are none
+    if (!imgs || imgs->num_parts == 0) {
+        p->osd_stats.cleared = true;
+        if (p->has_subtitle || p->cachedSubtitleImage || p->cachedSubtitleBuffer) {
+            p->has_subtitle = false;
+            p->osd_change_id = 0;  // Reset change_id so next subtitle renders
+            if (p->cachedSubtitleImage) {
+                CGImageRelease(p->cachedSubtitleImage);
+                p->cachedSubtitleImage = NULL;
+            }
+            if (p->cachedSubtitleBuffer) {
+                CVPixelBufferRelease(p->cachedSubtitleBuffer);
+                p->cachedSubtitleBuffer = NULL;
+            }
+            if (!p->composite_osd)
+                p->osd_needs_enqueue = true;
+        }
+        p->osd_stats.callback_ns += mp_time_ns() - callback_start;
+        return;
+    }
+
+    // Skip redraw if content hasn't changed AND we already have a subtitle cached
+    // This prevents unnecessary re-rendering but ensures we don't skip first render
+    bool has_cached_subtitle = p->composite_osd
+        ? p->cachedSubtitleImage != NULL
+        : p->cachedSubtitleBuffer != NULL;
+    if (imgs->change_id != 0 && imgs->change_id == p->osd_change_id &&
+        p->has_subtitle && has_cached_subtitle) {
+        p->osd_stats.cache_hit = true;
+        p->osd_stats.callback_ns += mp_time_ns() - callback_start;
+        return;
+    }
+
+    if (p->composite_osd) {
+        CGImageRef subtitleImage = render_subtitle_image(vo, imgs);
+        if (!subtitleImage) {
+            p->osd_stats.callback_ns += mp_time_ns() - callback_start;
+            return;
+        }
+
+        if (p->cachedSubtitleImage)
+            CGImageRelease(p->cachedSubtitleImage);
+        p->cachedSubtitleImage = subtitleImage;
+    } else {
+        CVPixelBufferRef subtitleBuffer = render_subtitle_pixel_buffer(vo, imgs);
+        if (!subtitleBuffer) {
+            p->osd_stats.callback_ns += mp_time_ns() - callback_start;
+            return;
+        }
+
+        if (p->cachedSubtitleBuffer)
+            CVPixelBufferRelease(p->cachedSubtitleBuffer);
+        p->cachedSubtitleBuffer = subtitleBuffer;
+    }
+
+    p->osd_stats.rendered = true;
+    p->osd_change_id = imgs->change_id;
+    p->has_subtitle = true;
+    if (!p->composite_osd)
+        p->osd_needs_enqueue = true;
+    p->osd_stats.callback_ns += mp_time_ns() - callback_start;
+}
+
+// Render OSD/subtitles for an already computed geometry.
+static bool render_osd_with_geometry(struct vo *vo, double pts,
+                                     struct avf_render_geometry geometry,
+                                     int64_t geometry_ns)
+{
+    struct priv *p = vo->priv;
+    reset_osd_render_stats(p);
+
+    if (!vo->osd)
+        return false;
+
+    // In composite mode, we don't need the osdLayer
+    if (!p->composite_osd && !p->osdLayer)
+        return false;
+
+    p->osd_stats.geometry_ns = geometry_ns;
+    struct mp_osd_res osd_res = geometry.osd_res;
+
+    if (geometry.w <= 0 || geometry.h <= 0 || osd_res.w <= 0 || osd_res.h <= 0)
+        return false;
+
+    if (!osd_res_equals(p->osd_res, osd_res)) {
+        p->osd_res = osd_res;
+        p->osd_change_id = 0;
+    }
+    p->osd_w = geometry.w;
+    p->osd_h = geometry.h;
+
+    static const bool formats[SUBBITMAP_COUNT] = {
+        [SUBBITMAP_BGRA] = true,
+        [SUBBITMAP_LIBASS] = true,
+    };
+
+    // Reset flag before calling osd_draw
+    p->osd_callback_invoked = false;
+
+    int64_t osd_draw_start = mp_time_ns();
+    osd_draw(vo->osd, osd_res, pts, 0, formats, draw_osd_cb, vo);
+    p->osd_stats.osd_draw_ns = mp_time_ns() - osd_draw_start;
+
+    // If callback wasn't invoked, there are no subtitles for this PTS
+    // Clear any cached subtitle state
+    if (!p->osd_callback_invoked && p->has_subtitle) {
+        p->has_subtitle = false;
+        p->osd_change_id = 0;
+        if (p->cachedSubtitleImage) {
+            CGImageRelease(p->cachedSubtitleImage);
+            p->cachedSubtitleImage = NULL;
+        }
+        if (p->cachedSubtitleBuffer) {
+            CVPixelBufferRelease(p->cachedSubtitleBuffer);
+            p->cachedSubtitleBuffer = NULL;
+        }
+        if (!p->composite_osd)
+            p->osd_needs_enqueue = true;
+    }
+
+    return true;
+}
+
+// Render OSD/subtitles synchronously. Used only by compositing mode, where the
+// subtitle image must exist before the video frame can be composited.
+static void render_osd(struct vo *vo, double pts)
+{
+    struct priv *p = vo->priv;
+    int64_t geometry_start = mp_time_ns();
+    int frame_w = p->next_image ? p->next_image->w : 0;
+    int frame_h = p->next_image ? p->next_image->h : 0;
+    struct avf_render_geometry geometry = get_render_geometry(vo, frame_w, frame_h);
+    int64_t geometry_ns = mp_time_ns() - geometry_start;
+
+    render_osd_with_geometry(vo, pts, geometry, geometry_ns);
+}
+
+// Composite subtitle onto video frame using Core Image (GPU) - HDR compatible
+static CVPixelBufferRef composite_frame(struct vo *vo, CVPixelBufferRef videoBuffer)
+{
+    struct priv *p = vo->priv;
+
+    if (!p->cachedSubtitleImage || !p->has_subtitle)
+        return NULL;
+
+    size_t videoW = CVPixelBufferGetWidth(videoBuffer);
+    size_t videoH = CVPixelBufferGetHeight(videoBuffer);
+
+    struct avf_render_geometry geometry = get_render_geometry(vo, (int)videoW, (int)videoH);
+    size_t outW = geometry.w > 0 ? (size_t)geometry.w : videoW;
+    size_t outH = geometry.h > 0 ? (size_t)geometry.h : videoH;
+    if (!outW || !outH)
+        return NULL;
+
+    struct mp_rect src = geometry.src;
+    struct mp_rect dst = geometry.dst;
+    if (src.x1 <= src.x0 || src.y1 <= src.y0 || dst.x1 <= dst.x0 || dst.y1 <= dst.y0)
+        return NULL;
+
+    CGRect outputRect = CGRectMake(0, 0, outW, outH);
+
+    // Detect original pixel format to preserve quality
+    OSType sourceFormat = CVPixelBufferGetPixelFormatType(videoBuffer);
+
+    // Ensure output pool matches dimensions and format
+    if (!create_output_pool(vo, (int)outW, (int)outH, sourceFormat))
+        return NULL;
+
+    // Get output buffer from pool
+    CVPixelBufferRef outputBuffer = NULL;
+    CVReturn status = CVPixelBufferPoolCreatePixelBuffer(
+        kCFAllocatorDefault, p->outputPool, &outputBuffer);
+
+    if (status != kCVReturnSuccess || !outputBuffer) {
+        MP_ERR(vo, "Failed to get output buffer from pool: %d\n", status);
+        return NULL;
+    }
+
+    // Copy HDR metadata from input to output buffer BEFORE rendering
+    copy_hdr_metadata(videoBuffer, outputBuffer);
+
+    // Use autoreleasepool to ensure CIImage objects are released promptly
+    @autoreleasepool {
+        // Create CIImages - preserve color space from source for HDR
+        CGColorSpaceRef srcColorSpace = CVImageBufferGetColorSpace(videoBuffer);
+        CGColorSpaceRef fallbackColorSpace = NULL;
+        if (!srcColorSpace) {
+            fallbackColorSpace = CGColorSpaceCreateWithName(kCGColorSpaceSRGB);
+            srcColorSpace = fallbackColorSpace;
+        }
+
+        CIImage *videoImage;
+        if (srcColorSpace) {
+            NSDictionary *videoOptions = @{
+                kCIImageColorSpace: (__bridge id)srcColorSpace
+            };
+            videoImage = [CIImage imageWithCVPixelBuffer:videoBuffer options:videoOptions];
+        } else {
+            videoImage = [CIImage imageWithCVPixelBuffer:videoBuffer];
+        }
+
+        if (fallbackColorSpace)
+            CGColorSpaceRelease(fallbackColorSpace);
+
+        if (!videoImage) {
+            CVPixelBufferRelease(outputBuffer);
+            return NULL;
+        }
+
+        CGRect srcRect = CGRectMake(src.x0, videoH - src.y1,
+                                   src.x1 - src.x0, src.y1 - src.y0);
+        CGFloat dstW = dst.x1 - dst.x0;
+        CGFloat dstH = dst.y1 - dst.y0;
+        CGFloat dstY = outH - dst.y1;
+
+        videoImage = [videoImage imageByCroppingToRect:srcRect];
+        videoImage = [videoImage imageByApplyingTransform:
+            CGAffineTransformMakeTranslation(-srcRect.origin.x, -srcRect.origin.y)];
+        videoImage = [videoImage imageByApplyingTransform:
+            CGAffineTransformMakeScale(dstW / srcRect.size.width, dstH / srcRect.size.height)];
+        videoImage = [videoImage imageByApplyingTransform:
+            CGAffineTransformMakeTranslation(dst.x0, dstY)];
+
+        CIImage *background = [[CIImage imageWithColor:
+            [CIColor colorWithRed:0 green:0 blue:0 alpha:1]] imageByCroppingToRect:outputRect];
+        videoImage = [videoImage imageByCompositingOverImage:background];
+
+        CIImage *subtitleImage = [CIImage imageWithCGImage:p->cachedSubtitleImage];
+
+        if (!subtitleImage) {
+            CVPixelBufferRelease(outputBuffer);
+            return NULL;
+        }
+
+        // Scale subtitle to match output dimensions
+        CGSize subSize = subtitleImage.extent.size;
+
+        if (subSize.width != (CGFloat)outW || subSize.height != (CGFloat)outH) {
+            CGFloat scaleX = (CGFloat)outW / subSize.width;
+            CGFloat scaleY = (CGFloat)outH / subSize.height;
+            subtitleImage = [subtitleImage imageByApplyingTransform:
+                CGAffineTransformMakeScale(scaleX, scaleY)];
+        }
+
+        // Composite subtitle over video
+        CIImage *composited = [subtitleImage imageByCompositingOverImage:videoImage];
+
+        // Render to output buffer, preserving color space
+        CGColorSpaceRef outputColorSpace = CVImageBufferGetColorSpace(videoBuffer);
+        if (outputColorSpace) {
+            [p->ciContext render:composited
+                 toCVPixelBuffer:outputBuffer
+                          bounds:outputRect
+                      colorSpace:outputColorSpace];
+        } else {
+            [p->ciContext render:composited toCVPixelBuffer:outputBuffer bounds:outputRect colorSpace:nil];
+        }
+    }
+
+    return outputBuffer;
+}
+
+static int preinit(struct vo *vo)
+{
+    struct priv *p = vo->priv;
+
+    if (vo->opts->WinID == -1) {
+        MP_ERR(vo, "No AVSampleBufferDisplayLayer provided via --wid\n");
+        return -1;
+    }
+
+    p->displayLayer = [(__bridge AVSampleBufferDisplayLayer *)(intptr_t)(vo->opts->WinID) retain];
+
+    MP_VERBOSE(vo, "displayLayer: %p, composite_osd: %s\n",
+               p->displayLayer, p->composite_osd ? "yes" : "no");
+
+    if (CMTimebaseCreateWithSourceClock(kCFAllocatorDefault,
+                                        CMClockGetHostTimeClock(),
+                                        &p->timebase) != noErr || !p->timebase) {
+        MP_ERR(vo, "Failed to create display layer timebase\n");
+        [p->displayLayer release];
+        p->displayLayer = nil;
+        return -1;
+    }
+
+    CMTimebaseSetTime(p->timebase, CMTimeMake(mp_time_ns(), NSEC_PER_SEC));
+    CMTimebaseSetRate(p->timebase, 1.0);
+    AVSampleBufferDisplayLayer *displayLayer = [p->displayLayer retain];
+    CMTimebaseRef timebase = p->timebase;
+    dispatch_main_sync_safe(^{
+        displayLayer.controlTimebase = timebase;
+    });
+    [displayLayer release];
+    vo_set_queue_params(vo, 128 * 1000 * 1000, 1);
+    update_avfoundation_geometry(vo);
+
+    // Setup Metal and Core Image for compositing mode (HDR-compatible)
+    if (p->composite_osd) {
+        p->mtlDevice = MTLCreateSystemDefaultDevice();
+        if (!p->mtlDevice) {
+            MP_ERR(vo, "Failed to create Metal device\n");
+            return -1;
+        }
+
+        // Use extended linear Display P3 color space for HDR compositing
+        // This color space can represent values > 1.0 needed for HDR
+        CGColorSpaceRef workingColorSpace = CGColorSpaceCreateWithName(
+            kCGColorSpaceExtendedLinearDisplayP3);
+        if (!workingColorSpace) {
+            workingColorSpace = CGColorSpaceCreateWithName(kCGColorSpaceExtendedSRGB);
+        }
+        if (!workingColorSpace) {
+            workingColorSpace = CGColorSpaceCreateWithName(kCGColorSpaceSRGB);
+        }
+
+        NSDictionary *ciOptions = workingColorSpace ? @{
+            kCIContextWorkingColorSpace: (__bridge id)workingColorSpace,
+            kCIContextHighQualityDownsample: @NO,
+            kCIContextUseSoftwareRenderer: @NO
+        } : @{
+            kCIContextHighQualityDownsample: @NO,
+            kCIContextUseSoftwareRenderer: @NO
+        };
+
+        p->ciContext = [[CIContext contextWithMTLDevice:p->mtlDevice options:ciOptions] retain];
+
+        if (workingColorSpace)
+            CGColorSpaceRelease(workingColorSpace);
+
+        if (!p->ciContext) {
+            MP_ERR(vo, "Failed to create CIContext\n");
+            return -1;
+        }
+
+        MP_VERBOSE(vo, "HDR-compatible compositing mode enabled with Metal\n");
+
+    }
+
+    // Create a timed OSD sample-buffer layer only if not in composite mode.
+    if (!p->composite_osd) {
+        AVSampleBufferDisplayLayer *displayLayer = [p->displayLayer retain];
+        CMTimebaseRef timebase = p->timebase;
+        dispatch_main_sync_safe(^{
+            AVSampleBufferDisplayLayer *osdLayer = [[AVSampleBufferDisplayLayer alloc] init];
+            osdLayer.frame = displayLayer.frame;
+            osdLayer.anchorPoint = CGPointMake(0.5, 0.5);
+#if !TARGET_OS_IPHONE
+            osdLayer.autoresizingMask = kCALayerWidthSizable | kCALayerHeightSizable;
+#endif
+            osdLayer.contentsScale = displayLayer.contentsScale > 0 ? displayLayer.contentsScale : get_screen_scale();
+            osdLayer.backgroundColor = NULL;
+            osdLayer.opaque = NO;
+            osdLayer.videoGravity = AVLayerVideoGravityResize;
+            osdLayer.controlTimebase = timebase;
+
+            CALayer *parent = displayLayer.superlayer;
+            if (parent) {
+                [parent addSublayer:osdLayer];
+                osdLayer.zPosition = displayLayer.zPosition + 1;
+            } else {
+                [displayLayer addSublayer:osdLayer];
+                osdLayer.frame = displayLayer.bounds;
+                MP_WARN(vo, "displayLayer has no superlayer; OSD will degrade direct scanout\n");
+            }
+            p->osdLayer = osdLayer;
+        });
+        [displayLayer release];
+    }
+
+    vo->hwdec_devs = hwdec_devices_create();
+    p->hwctx = (struct mp_hwdec_ctx){
+        .driver_name = "avfoundation",
+        .av_device_ref = create_videotoolbox_device_ref(vo),
+        .hw_imgfmt = IMGFMT_VIDEOTOOLBOX,
+    };
+    hwdec_devices_add(vo->hwdec_devs, &p->hwctx);
+
+    return 0;
+}
+
+static CMSampleBufferRef create_video_sample_buffer(struct vo *vo, mp_image_t *mpi)
+{
+    @autoreleasepool {
+        struct priv *p = vo->priv;
+
+        CVPixelBufferRef pixbuf = NULL;
+        bool pixbufNeedsRelease = false;
+
+        // Handle different input formats
+        if (mpi->imgfmt == IMGFMT_VIDEOTOOLBOX) {
+            // Hardware decoded: zero-copy passthrough
+            pixbuf = (CVPixelBufferRef)mpi->planes[3];
+        } else {
+            // Software decoded: upload to CVPixelBuffer
+            pixbuf = upload_software_frame(vo, mpi);
+            if (!pixbuf) {
+                MP_ERR(vo, "Failed to upload software frame\n");
+                return NULL;
+            }
+            pixbufNeedsRelease = true;
+        }
+
+        CVPixelBufferRef finalBuffer = pixbuf;
+        bool needsRelease = false;
+
+        // In composite mode, composite the subtitle image rendered for this flip.
+        if (p->composite_osd) {
+            CVPixelBufferRef composited = composite_frame(vo, pixbuf);
+            if (composited) {
+                finalBuffer = composited;
+                needsRelease = true;
+            }
+        }
+
+        CMSampleTimingInfo info = {
+            .presentationTimeStamp = CMTimeMake(p->next_present_host_ns, NSEC_PER_SEC),
+            .duration = kCMTimeInvalid,
+            .decodeTimeStamp = kCMTimeInvalid
+        };
+
+        CMSampleBufferRef buf = NULL;
+        CMFormatDescriptionRef format = NULL;
+        OSStatus err = CMVideoFormatDescriptionCreateForImageBuffer(NULL, finalBuffer, &format);
+        if (err != noErr || !format) {
+            MP_ERR(vo, "Failed to create format description: %d\n", (int)err);
+            if (needsRelease)
+                CVPixelBufferRelease(finalBuffer);
+            if (pixbufNeedsRelease)
+                CVPixelBufferRelease(pixbuf);
+            return NULL;
+        }
+
+        err = CMSampleBufferCreateReadyWithImageBuffer(NULL, finalBuffer, format, &info, &buf);
+        CFRelease(format);
+
+        if (err != noErr || !buf) {
+            MP_ERR(vo, "Failed to create sample buffer: %d\n", (int)err);
+            if (needsRelease)
+                CVPixelBufferRelease(finalBuffer);
+            if (pixbufNeedsRelease)
+                CVPixelBufferRelease(pixbuf);
+            return NULL;
+        }
+
+        // Release composited output buffer (always owned by us)
+        if (needsRelease)
+            CVPixelBufferRelease(finalBuffer);
+
+        // Release uploaded software frame buffer (owned by us, not by mpi)
+        if (pixbufNeedsRelease)
+            CVPixelBufferRelease(pixbuf);
+
+        return buf;
+    }
+}
+
+static bool enqueue_video_sample(struct vo *vo, CMSampleBufferRef buf)
+{
+    struct priv *p = vo->priv;
+
+    if (!buf)
+        return false;
+
+    [p->displayLayer enqueueSampleBuffer:buf];
+    return true;
+}
+
+static void log_flip_timing(struct vo *vo, int64_t present_host_ns,
+                            int64_t start_ns, int64_t osd_done_ns,
+                            int64_t osd_sample_done_ns,
+                            int64_t video_sample_done_ns,
+                            int64_t done_ns, bool osd_needed,
+                            bool osd_enqueued, bool video_enqueued)
+{
+    struct priv *p = vo->priv;
+    int64_t total_ns = done_ns - start_ns;
+    int64_t margin_ns = present_host_ns - done_ns;
+
+    if (osd_enqueued && video_enqueued && total_ns < MP_TIME_MS_TO_NS(16) &&
+        margin_ns > MP_TIME_MS_TO_NS(4))
+        return;
+
+    MP_VERBOSE(vo,
+        "AVF flip timing: render=%.2fms osd-sample=%.2fms video-sample=%.2fms total=%.2fms margin=%.2fms osd=%s video=%s\n",
+        (osd_done_ns - start_ns) / 1000000.0,
+        (osd_sample_done_ns - osd_done_ns) / 1000000.0,
+        (video_sample_done_ns - osd_sample_done_ns) / 1000000.0,
+        total_ns / 1000000.0,
+        margin_ns / 1000000.0,
+        osd_needed ? (osd_enqueued ? "enqueued" : "missed") : "none",
+        video_enqueued ? "enqueued" : "missed");
+
+    struct avf_osd_render_stats *s = &p->osd_stats;
+    if (s->geometry_ns || s->osd_draw_ns || s->callbacks) {
+        int64_t internal_ns = s->osd_draw_ns > s->callback_ns
+            ? s->osd_draw_ns - s->callback_ns : 0;
+        int bbox_w = s->has_bbox ? s->bbox_x1 - s->bbox_x0 : 0;
+        int bbox_h = s->has_bbox ? s->bbox_y1 - s->bbox_y0 : 0;
+
+        MP_VERBOSE(vo,
+            "AVF render detail: geometry=%.2fms osd-draw=%.2fms mpv-libass=%.2fms callback=%.2fms buffer=%.2fms context=%.2fms bitmap=%.2fms callbacks=%d parts=%d format=%s path=%s src-px=%lld dst-px=%lld bbox=%dx%d state=%s%s%s%s\n",
+            s->geometry_ns / 1000000.0,
+            s->osd_draw_ns / 1000000.0,
+            internal_ns / 1000000.0,
+            s->callback_ns / 1000000.0,
+            s->buffer_ns / 1000000.0,
+            s->context_ns / 1000000.0,
+            s->bitmap_draw_ns / 1000000.0,
+            s->callbacks,
+            s->parts,
+            sub_bitmap_format_name(s->format),
+            osd_draw_path_name(s->draw_path),
+            (long long)s->src_pixels,
+            (long long)s->dst_pixels,
+            bbox_w,
+            bbox_h,
+            s->has_output ? "output" : "empty",
+            s->rendered ? ",rendered" : "",
+            s->cache_hit ? ",cache-hit" : "",
+            s->cleared ? ",cleared" : "");
+    }
+}
+
+static void flip_page(struct vo *vo)
+{
+    struct priv *p = vo->priv;
+
+    if (p->next_image) {
+        int64_t start_ns = mp_time_ns();
+        CMSampleBufferRef osd_buf = NULL;
+        bool osd_needed = false;
+
+        render_osd(vo, p->next_pts);
+        int64_t osd_done_ns = mp_time_ns();
+
+        osd_buf = create_osd_sample_buffer(vo,
+            p->next_present_host_ns, &osd_needed);
+        int64_t osd_sample_done_ns = mp_time_ns();
+
+        CMSampleBufferRef video_buf = create_video_sample_buffer(vo, p->next_image);
+        int64_t video_sample_done_ns = mp_time_ns();
+
+        bool osd_enqueued = !osd_needed;
+        bool video_enqueued = false;
+
+        if (video_buf && wait_until_ready_for_more_media_data(vo, p->next_present_host_ns)) {
+            if (osd_buf) {
+                osd_enqueued = enqueue_osd_sample(vo, osd_buf);
+                if (osd_enqueued)
+                    p->osd_needs_enqueue = false;
+            }
+
+            video_enqueued = enqueue_video_sample(vo, video_buf);
+        }
+
+        if (osd_needed && !osd_enqueued)
+            p->osd_change_id = 0;
+
+        if (osd_buf)
+            CFRelease(osd_buf);
+        if (video_buf)
+            CFRelease(video_buf);
+
+        log_flip_timing(vo, p->next_present_host_ns, start_ns, osd_done_ns,
+            osd_sample_done_ns, video_sample_done_ns, mp_time_ns(), osd_needed,
+            osd_enqueued, video_enqueued);
+    }
+
+    // Flush excess buffers every ~60 frames to prevent memory growth
+    // without causing buffer churn on every frame
+    if (++p->frame_count >= 60) {
+        p->frame_count = 0;
+        if (p->outputPool)
+            CVPixelBufferPoolFlush(p->outputPool, kCVPixelBufferPoolFlushExcessBuffers);
+        if (p->osdPool)
+            CVPixelBufferPoolFlush(p->osdPool, kCVPixelBufferPoolFlushExcessBuffers);
+        if (p->swUploadPool)
+            CVPixelBufferPoolFlush(p->swUploadPool, kCVPixelBufferPoolFlushExcessBuffers);
+    }
+
+    mp_image_unrefp(&p->next_image);
+}
+
+static bool draw_frame(struct vo *vo, struct vo_frame *frame)
+{
+    struct priv *p = vo->priv;
+
+    mp_image_unrefp(&p->next_image);
+
+    if (!frame->current || (frame->repeat && !frame->redraw)) {
+        p->next_pts = MP_NOPTS_VALUE;
+        p->next_present_host_ns = mp_time_ns();
+        return true;
+    }
+
+    p->next_image = mp_image_new_ref(frame->current);
+    if (!p->next_image)
+        return false;
+
+    double pts = p->next_image->pts;
+    if (pts == MP_NOPTS_VALUE)
+        pts = frame->current->pts;
+    if (pts == MP_NOPTS_VALUE)
+        pts = frame->pts;
+
+    p->next_pts = pts;
+    p->next_present_host_ns = frame->pts > 0 ? frame->pts : mp_time_ns();
+    return true;
+}
+
+static int query_format(struct vo *vo, int format)
+{
+    switch (format) {
+        case IMGFMT_VIDEOTOOLBOX:  // Hardware decoded (zero-copy)
+        case IMGFMT_NV12:          // Software decoded (common)
+        case IMGFMT_420P:          // YUV420P (very common)
+        case IMGFMT_P010:          // 10-bit (HDR software decode)
+            return 1;
+        default:
+            return 0;
+    }
+}
+
+static void clear_subtitle_cache(struct priv *p)
+{
+    if (p->cachedSubtitleImage) {
+        CGImageRelease(p->cachedSubtitleImage);
+        p->cachedSubtitleImage = NULL;
+    }
+    if (p->cachedSubtitleBuffer) {
+        CVPixelBufferRelease(p->cachedSubtitleBuffer);
+        p->cachedSubtitleBuffer = NULL;
+    }
+    p->has_subtitle = false;
+    p->osd_change_id = 0;
+    p->osd_needs_enqueue = false;
+    p->osd_callback_invoked = false;
+    reset_osd_render_stats(p);
+}
+
+// Helper to clear all subtitle state (called on video change/stop)
+static void clear_subtitle_state(struct vo *vo)
+{
+    struct priv *p = vo->priv;
+
+    clear_subtitle_cache(p);
+
+    if (!p->composite_osd && p->osdLayer) {
+        AVSampleBufferDisplayLayer *osdLayer = [p->osdLayer retain];
+        if (!osdLayer)
+            return;
+        dispatch_async(dispatch_get_main_queue(), ^{
+            [osdLayer flushAndRemoveImage];
+            [osdLayer release];
+        });
+    }
+}
+
+static int reconfig(struct vo *vo, struct mp_image_params *params)
+{
+    MP_VERBOSE(vo, "reconfig: %dx%d\n", params->w, params->h);
+
+    // Clear subtitles when video configuration changes
+    clear_subtitle_state(vo);
+    sync_osd_layer_frame(vo);
+
+    return 0;
+}
+
+static void uninit(struct vo *vo)
+{
+    struct priv *p = vo->priv;
+
+    mp_image_unrefp(&p->next_image);
+    [p->displayLayer flushAndRemoveImage];
+    [p->osdLayer flushAndRemoveImage];
+
+    if (p->timebase) {
+        AVSampleBufferDisplayLayer *displayLayer = [p->displayLayer retain];
+        AVSampleBufferDisplayLayer *osdLayer = [p->osdLayer retain];
+        dispatch_main_sync_safe(^{
+            displayLayer.controlTimebase = NULL;
+            osdLayer.controlTimebase = NULL;
+        });
+        [displayLayer release];
+        [osdLayer release];
+        CFRelease(p->timebase);
+        p->timebase = NULL;
+    }
+
+    if (p->cachedSubtitleImage) {
+        CGImageRelease(p->cachedSubtitleImage);
+        p->cachedSubtitleImage = NULL;
+    }
+
+    if (p->cachedSubtitleBuffer) {
+        CVPixelBufferRelease(p->cachedSubtitleBuffer);
+        p->cachedSubtitleBuffer = NULL;
+    }
+
+    if (p->outputPool) {
+        CVPixelBufferPoolRelease(p->outputPool);
+        p->outputPool = NULL;
+    }
+
+    if (p->osdPool) {
+        CVPixelBufferPoolRelease(p->osdPool);
+        p->osdPool = NULL;
+    }
+
+    if (p->swUploadPool) {
+        CVPixelBufferPoolRelease(p->swUploadPool);
+        p->swUploadPool = NULL;
+    }
+
+    if (!p->composite_osd) {
+        AVSampleBufferDisplayLayer *osdLayer = p->osdLayer;
+        p->osdLayer = nil;
+        if (osdLayer) {
+            dispatch_main_sync_safe(^{
+                [osdLayer removeFromSuperlayer];
+            });
+            [osdLayer release];
+        }
+    }
+
+    [p->ciContext release];
+    p->ciContext = nil;
+    [p->mtlDevice release];
+    p->mtlDevice = nil;
+
+    [p->displayLayer release];
+    p->displayLayer = nil;
+
+    hwdec_devices_remove(vo->hwdec_devs, &p->hwctx);
+    av_buffer_unref(&p->hwctx.av_device_ref);
+}
+
+static int control(struct vo *vo, uint32_t request, void *data)
+{
+    struct priv *p = vo->priv;
+
+    switch (request) {
+    case VOCTRL_SET_PANSCAN:
+        sync_osd_layer_frame(vo);
+        return VO_TRUE;
+    case VOCTRL_RESET:
+        // Called when playback stops or video changes
+        clear_subtitle_state(vo);
+        [p->displayLayer flushAndRemoveImage];
+        [p->osdLayer flushAndRemoveImage];
+        if (p->timebase)
+            CMTimebaseSetTime(p->timebase, CMTimeMake(mp_time_ns(), NSEC_PER_SEC));
+        return VO_TRUE;
+    case VOCTRL_REDRAW:
+        p->osd_change_id = 0;
+        return VO_TRUE;
+    case VOCTRL_UPDATE_WINDOW_TITLE:
+        return VO_TRUE;
+    }
+    return VO_NOTIMPL;
+}
+
+
+#define OPT_BASE_STRUCT struct priv
+static const struct m_option options[] = {
+    {"composite-osd", OPT_BOOL(composite_osd)},
+    {0},
+};
+
+const struct vo_driver video_out_avfoundation = {
+    .description = "AVFoundation AVSampleBufferDisplayLayer (macOS/iOS)",
+    .name = "avfoundation",
+    .caps = 0,
+    .preinit = preinit,
+    .query_format = query_format,
+    .control = control,
+    .draw_frame = draw_frame,
+    .flip_page = flip_page,
+    .reconfig = reconfig,
+    .uninit = uninit,
+    .priv_size = sizeof(struct priv),
+    .options = options,
+    .options_prefix = "avfoundation",
+};
